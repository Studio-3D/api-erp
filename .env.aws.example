APP_NAME="Laravel API"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_HERE
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL (Vercel)
FRONTEND_URL=https://frontend-0-2.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# AWS RDS Database (use your actual RDS endpoint)
DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Client Database (same RDS instance)
DB_CONNECTION_CLIENT=mysql
DB_HOST_CLIENT=your-rds-endpoint.rds.amazonaws.com
DB_PORT_CLIENT=3306
DB_DATABASE_CLIENT=your_client_database
DB_USERNAME_CLIENT=your_username
DB_PASSWORD_CLIENT=your_password

# Broadcasting & Caching (using simple file drivers for now)
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (Not needed - using file driver)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# AWS S3 Storage (Not needed - using local storage)
# When you need S3, create bucket in AWS Console and update these:
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=eu-north-1
# AWS_BUCKET=immogestion-storage
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (using your existing credentials)
PUSHER_APP_ID=1728382
PUSHER_APP_KEY=cb0195da05309b23fb11
PUSHER_APP_SECRET=1af2e50be179fd69eb59
PUSHER_APP_CLUSTER=eu

# Mail
MAIL_MAILER=smtp
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=your_ses_smtp_username
MAIL_PASSWORD=your_ses_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Deployment flags
RUN_MIGRATIONS=true
INSTALL_PASSPORT=false
